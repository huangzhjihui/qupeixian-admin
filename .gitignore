# ==============================
# 趣配鲜 - Git 忽略规则
# ==============================

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 环境变量（敏感文件，绝不能提交）
.env
.env.local
.env.*.local

# 数据库文件（开发数据）
database/*.sqlite
database/*.sqlite3
backend/database/*.sqlite

# 日志文件
logs/
*.log

# 上传文件（用户生成内容）
backend/public/uploads/
uploads/

# 构建产物
frontend/dist/
dist/
build/

# 备份文件
backups/
*.bak
*.sql.gz

# 临时/测试脚本
test-*.js
test-*.html
debug-*.js
check-*.js
fix-*.js
diagnose.js
gen-secrets.js
update-images.js
download-images.js
test_export.xlsx

# 截图和临时图片
*.png
sala.jpg

# 安装包（文件太大）
node.zip
node-installer.msi
node/

# IDE / 编辑器
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# 系统文件
*.pid
*.seed
*.pid.lock
