# ===========================================
# 趣配鲜 - 后端环境配置示例
# ===========================================

# 应用配置
NODE_ENV=development
PORT=3000
APP_NAME=趣配鲜
APP_URL=http://localhost:3000
API_PREFIX=/api/v1

# JWT密钥 (生产环境请使用强密钥)
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_change_this_in_production
JWT_REFRESH_EXPIRE=30d

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=qupeixian
DB_USER=root
DB_PASSWORD=your_password
DB_CHARSET=utf8mb4

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# 加密密钥 (生产环境请使用强密钥)
ENCRYPT_KEY=your_encrypt_key_change_this_in_production

# 微信支付配置
WECHAT_APPID=your_wechat_appid
WECHAT_MCHID=your_wechat_mchid
WECHAT_API_KEY=your_wechat_api_key
WECHAT_CERT_PATH=./certs/apiclient_cert.p12
WECHAT_NOTIFY_URL=https://your-domain.com/api/v1/payment/wechat/notify

# 微信小程序配置
WECHAT_MINI_APPID=your_mini_appid
WECHAT_MINI_SECRET=your_mini_secret

# 文件上传配置
UPLOAD_DIR=./public/uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,mp4

# 日志配置
LOG_LEVEL=info
LOG_DIR=./logs

# 安全配置
CORS_ORIGIN=*
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# 备份配置
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30
