# ===========================================
# 趣配鲜 - 生产环境配置模板
# ===========================================
# 复制此文件为 .env 并填写实际值
# cp .env.production.example .env

# 应用配置
NODE_ENV=production
PORT=3000
APP_NAME=趣配鲜
APP_URL=https://your-domain.com
API_PREFIX=/api

# JWT密钥 (必须设置，使用 openssl rand -hex 64 生成)
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_REFRESH_EXPIRE=30d

# 数据库配置 - MySQL (推荐生产环境使用)
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=qupeixian
DB_USER=qupeixian
DB_PASSWORD=your_db_password

# 或使用 SQLite (小规模部署)
# DB_CONNECTION=sqlite
# DB_FILENAME=./database/production.sqlite

# Redis配置 (推荐开启，用于缓存和会话)
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379

# 加密密钥 (必须设置，使用 openssl rand -hex 32 生成)
ENCRYPT_KEY=your_encrypt_key_here

# 微信支付配置 (必须对接真实支付)
WECHAT_APPID=your_wechat_appid
WECHAT_MCHID=your_wechat_mchid
WECHAT_API_KEY=your_wechat_api_key
WECHAT_NOTIFY_URL=https://your-domain.com/api/payment/wechat/notify

# 微信小程序配置
WECHAT_MINI_APPID=your_mini_appid
WECHAT_MINI_SECRET=your_mini_secret

# 文件上传配置
UPLOAD_DIR=./public/uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,mp4

# 日志配置
LOG_LEVEL=warn
LOG_DIR=./logs

# 安全配置 (限制为你的域名)
CORS_ORIGIN=https://your-domain.com,https://www.your-domain.com
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=500

# 备份配置
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30
